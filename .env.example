# Real-Debrid (required)
RD_API_KEY=your_rd_api_key

# Trakt (required)
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
TRAKT_REDIRECT_URI=https://my-stremio-addon-981079721173.us-central1.run.app/trakt/callback

# Upstash Redis (required for Trakt token storage)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Base URL (your Cloud Run URL)
BASE_URL=https://my-stremio-addon-981079721173.us-central1.run.app
